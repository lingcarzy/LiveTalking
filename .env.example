# LiveTalking 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== LLM 默认配置 ====================
# 支持: grok / deepseek / ollama / dashscope / openai
LLM_PROVIDER=grok
# 可选：不填则按 provider 使用默认模型
# LLM_MODEL=grok-4.20-fast-non-reasoning

# 可选：统一代理（如需）
# LLM_PROXY=http://127.0.0.1:10808

# ==================== LLM API 密钥 ====================
# 阿里 DashScope (通义千问)
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# 或统一写法
# LIVETALKING_LLM_API_KEY=your-llm-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# Grok / xAI
GROK_API_KEY=xai-xxxxxxxxxxxxxxxx
# 兼容变量名
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxx
# 可选 Grok 代理
GROK_PROXY=http://127.0.0.1:10808

# Ollama（本地一般不需要 API key）
# OLLAMA_API_KEY=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# ==================== 腾讯云 TTS ====================
TENCENT_APPID=your-tencent-appid
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_SECRET_ID=your-tencent-secret-id

# ==================== 字节豆包 TTS ====================
DOUBAO_APPID=your-doubao-appid
DOUBAO_TOKEN=your-doubao-token

# ==================== Azure TTS ====================
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_TTS_REGION=eastasia

# ==================== 安全与性能限制（可选） ====================
# MAX_CHAT_CHARS=4000
# MAX_AUDIO_UPLOAD_MB=20
# MAX_CUSTOM_CONFIG_CHARS=50000
# LLM_REQUEST_TIMEOUT=60
# LLM_HISTORY_TURNS=6
